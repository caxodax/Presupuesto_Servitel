# Ambiente
NODE_ENV=development

# SUPABASE CONFIG
# Se obtienen del panel de configuración de tu proyecto Supabase -> API
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# SERVICE ROLE (Solo para acciones administrativas o bypass RLS en servidor)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# Cloudflare R2 (Opcional, para adjuntos si no se usa Supabase Storage)
# R2_ACCOUNT_ID=tu-account-id
# R2_ACCESS_KEY_ID=tu-access-key
# R2_SECRET_ACCESS_KEY=tu-secret-key
# R2_BUCKET_NAME=tu-bucket

# Auth Config
# Se puede generar con: npx auth secret
AUTH_SECRET="super-secret-key-development-only-123"
NEXTAUTH_URL="http://localhost:3000"
