datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  OPERATOR
  AUDITOR
  VIEWER
}

enum BudgetPeriodType {
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
}

enum BudgetStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum InvoiceStatus {
  REGISTERED
  CANCELLED
}

enum AlertType {
  BUDGET_EXCEEDED
  ADJUSTMENT_MADE
  SYSTEM_WARNING
}

model Company {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches  Branch[]
  users     User[]
  categories Category[]
  budgets   Budget[]
  invoices  Invoice[]
  auditLogs AuditLog[]
  alerts    Alert[]
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  companyId String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users     User[]
  budgets   Budget[]

  @@index([companyId])
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String
  role          Role     @default(OPERATOR)
  companyId     String?
  branchId      String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  branch        Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  auditLogs     AuditLog[]
  invoices      Invoice[] @relation("InvoiceRegisteredBy")
  adjustments   BudgetAdjustment[] @relation("BudgetAdjustmentRecordedBy")

  @@index([companyId])
  @@index([branchId])
}

model Category {
  id            String   @id @default(cuid())
  name          String
  companyId     String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subcategories Subcategory[]
  allocations   BudgetAllocation[]

  @@unique([name, companyId])
  @@index([companyId])
}

model Subcategory {
  id            String   @id @default(cuid())
  name          String
  categoryId    String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category      Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  allocations   BudgetAllocation[]

  @@unique([name, categoryId])
  @@index([categoryId])
}

model Budget {
  id            String           @id @default(cuid())
  name          String
  type          BudgetPeriodType @default(MONTHLY)
  initialDate   DateTime
  endDate       DateTime
  amountLimitUSD Decimal         @db.Decimal(19,4)
  status        BudgetStatus     @default(ACTIVE)
  companyId     String
  branchId      String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch        Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  allocations   BudgetAllocation[]

  @@index([companyId, initialDate, endDate])
  @@index([branchId])
}

model BudgetAllocation {
  id            String    @id @default(cuid())
  budgetId      String
  categoryId    String
  subcategoryId String?
  amountUSD     Decimal   @db.Decimal(19,4)
  amountVES     Decimal   @default(0) @db.Decimal(19,4)
  consumedUSD   Decimal   @default(0) @db.Decimal(19,4)
  consumedVES   Decimal   @default(0) @db.Decimal(19,4)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  budget        Budget    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  category      Category  @relation(fields: [categoryId], references: [id])
  subcategory   Subcategory? @relation(fields: [subcategoryId], references: [id])
  adjustments   BudgetAdjustment[]
  invoices      Invoice[]

  @@unique([budgetId, categoryId, subcategoryId])
  @@index([budgetId])
  @@index([categoryId])
}

model BudgetAdjustment {
  id            String   @id @default(cuid())
  allocationId  String
  reason        String
  amountUSD     Decimal  @db.Decimal(19,4)
  amountVES     Decimal  @default(0) @db.Decimal(19,4)
  recordedById  String
  createdAt     DateTime @default(now())

  allocation    BudgetAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  recordedBy    User             @relation("BudgetAdjustmentRecordedBy", fields: [recordedById], references: [id])

  @@index([allocationId])
  @@index([recordedById])
}

model Invoice {
  id             String        @id @default(cuid())
  number         String
  supplierName   String
  allocationId   String
  amountUSD      Decimal       @db.Decimal(19,4)
  amountVES      Decimal       @db.Decimal(19,4)
  exchangeRate   Decimal       @db.Decimal(19,4)
  date           DateTime
  companyId      String
  registeredById String
  status         InvoiceStatus @default(REGISTERED)
  attachmentKey  String?
  attachmentName String?
  createdAt      DateTime      @default(now())

  updatedAt      DateTime      @updatedAt

  allocation     BudgetAllocation @relation(fields: [allocationId], references: [id], onDelete: Restrict)
  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  registeredBy   User             @relation("InvoiceRegisteredBy", fields: [registeredById], references: [id])

  @@index([companyId, date])
  @@index([allocationId])
  @@index([registeredById])
}

model AuditLog {
  id          String   @id @default(cuid())
  companyId   String?
  userId      String
  action      String
  entity      String
  entityId    String
  details     Json?
  createdAt   DateTime @default(now())

  company     Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])

  @@index([companyId, createdAt])
  @@index([entity, entityId])
}

model Alert {
  id          String    @id @default(cuid())
  companyId   String
  type        AlertType
  title       String
  message     String
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, isRead, createdAt])
}
